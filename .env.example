# ===================================
# Arker CRM - Variaveis de Ambiente
# ===================================

# ----------------------------------
# PostgreSQL (Supabase)
# ----------------------------------
# Pooler (runtime)
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"

# Conexao direta (CLI / migrations)
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# ----------------------------------
# API Backend local
# ----------------------------------
NEXT_PUBLIC_API_URL="http://localhost:5000"

# ----------------------------------
# Versao do app
# ----------------------------------
NEXT_PUBLIC_APP_VERSION="0.1.0"

# ----------------------------------
# Autenticacao (NextAuth.js)
# ----------------------------------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
# Chave service_role (Project Settings > API). Obrigatoria para envio via Resend (generateLink).
# NUNCA expor no cliente.
SUPABASE_SERVICE_ROLE_KEY=""
# Opcional. Se vazio, usa NEXTAUTH_URL + /auth/confirm
# Se definir apenas a origem (ex: https://app.com), o codigo adiciona /auth/confirm automaticamente
SUPABASE_AUTH_EMAIL_REDIRECT_URL=""
# Credenciais OAuth do app Google (usadas para refresh de token do Drive no backend)
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
# OBRIGATORIO no Supabase Dashboard > Auth > URL Configuration:
# - Site URL: sua URL principal (ex: https://app.com ou http://localhost:3000)
# - Redirect URLs (adicione TODAS que usa):
#   * {ORIGEM}/auth/callback   (login Google)
#   * {ORIGEM}/auth/confirm   (confirmacao de email no registro)
#   * {ORIGEM}/auth/reset-password (esqueci minha senha)
# Exemplo dev: http://localhost:3000/auth/callback, http://localhost:3000/auth/confirm
SEED_ADMIN_TOKEN=""
DISABLE_HEAVY_ROUTES="false"
BILLING_SUBSCRIPTION_ENABLED="false"
NEXT_PUBLIC_BILLING_SUBSCRIPTION_ENABLED="false"
PRISMA_SLOW_QUERY_LOG_ENABLED="false"
PRISMA_SLOW_QUERY_THRESHOLD_MS="300"

# Rate limit de autenticacao (segundos)
AUTH_LOGIN_WINDOW_SECONDS="600"
AUTH_LOGIN_MAX_ATTEMPTS="5"
AUTH_LOGIN_BLOCK_SECONDS="900"
AUTH_REGISTER_WINDOW_SECONDS="1800"
AUTH_REGISTER_MAX_ATTEMPTS="5"
AUTH_REGISTER_BLOCK_SECONDS="1800"
AUTH_FORGOT_PASSWORD_WINDOW_SECONDS="1800"
AUTH_FORGOT_PASSWORD_MAX_ATTEMPTS="3"
AUTH_FORGOT_PASSWORD_BLOCK_SECONDS="1800"
AUTH_RESEND_CONFIRMATION_WINDOW_SECONDS="1800"
AUTH_RESEND_CONFIRMATION_MAX_ATTEMPTS="3"
AUTH_RESEND_CONFIRMATION_BLOCK_SECONDS="1800"

# Codigos de registro (separados por virgula ou quebra de linha)
# Exemplo: CODE1,CODE2,CODE3
REGISTRATION_CODES=""

# ----------------------------------
# Resend (emails transacionais + MCP)
# ----------------------------------
# Chave da API Resend (criar em https://resend.com/api-keys)
# Usada pelo SDK Resend e pelo MCP Resend (Cursor).
# Para o MCP: substitua re_xxxxxxxxx no .mcp.json pela sua chave.
RESEND_API_KEY=
# Remetente dos emails (ex: "Arker CRM <no-reply@seudominio.com>")
# Se vazio, usa onboarding@resend.dev (apenas para testes)
RESEND_FROM_EMAIL=

# Scheduler / Operações sensíveis
LEADS_SCHEDULER_SECRET=
CRON_SECRET=
FINANCE_SCHEDULER_SECRET=

# ----------------------------------
# IA - Mapeamento de importacao (opcional)
# ----------------------------------
# Chave da API Google Gemini para sugestao automatica de mapeamento de colunas.
# Se nao configurada, o sistema usa mapeamento heurístico.
GEMINI_API_KEY=

# ----------------------------------
# Assinatura (Stripe)
# ----------------------------------
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# Opcional: bloquear checkout em modo teste e aceitar apenas chave/checkout live
# STRIPE_LIVE_MODE_ONLY=true
# Chave publica para checkout embedded (comeca com pk_)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Planos premium (criar 3 produtos no Stripe e colar os Price IDs)
# STRIPE_PRICE_ID_PLAN_1=      # 1 licença - Individual
# STRIPE_PRICE_ID_PLAN_3=      # 3 licenças - Equipe (permite gerente)
# STRIPE_PRICE_ID_PLAN_5=      # 5 licenças - Equipe
# STRIPE_PRICE_ID_PLAN_10_PLUS= # 10 licenças - Enterprise (permite gerente)

# WhatsApp para plano Personalizado (formato: 5511999999999)
# NEXT_PUBLIC_WHATSAPP_PLAN_PERSONALIZADO=5519998205608


# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
