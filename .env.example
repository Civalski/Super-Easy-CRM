# Copie para `.env` ou `.env.local` e preencha com valores reais.
# Nunca commite arquivos `.env` com segredos.

# -----------------------------------------------------------------------------
# Edição do CRM (build-time, exposto ao cliente como NEXT_PUBLIC_*)
# -----------------------------------------------------------------------------
# Omita ou deixe vazio para a edição completa (produção comercial).
# Use "oss" para restringir a interface e as APIs ao funil (/grupos + /oportunidades),
# clientes e tarefas (demais rotas retornam 403 ou redirecionam).
NEXT_PUBLIC_CRM_EDITION=

# -----------------------------------------------------------------------------
# Banco de dados
# -----------------------------------------------------------------------------
DATABASE_URL=
DIRECT_URL=

# -----------------------------------------------------------------------------
# NextAuth
# -----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
# NEXTAUTH_DEBUG=true

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# URL de redirecionamento apos confirmar e-mail (padrao: NEXTAUTH_URL)
# SUPABASE_AUTH_EMAIL_REDIRECT_URL=

# -----------------------------------------------------------------------------
# E-mail (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@seudominio.com
# Logo nos e-mails (confirmacao / esqueci senha). Se vazio, usa o logo em arkersoft.com.br.
EMAIL_LOGO_URL=

# -----------------------------------------------------------------------------
# Cloudflare Turnstile (anti-bot)
# -----------------------------------------------------------------------------
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# -----------------------------------------------------------------------------
# Stripe (billing)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=
# STRIPE_PRICE_ID_PLAN_1=
# STRIPE_LIVE_MODE_ONLY=true
# BILLING_SUBSCRIPTION_ENABLED=true
# NEXT_PUBLIC_BILLING_SUBSCRIPTION_ENABLED=true

# -----------------------------------------------------------------------------
# Google OAuth (Drive integration)
# -----------------------------------------------------------------------------
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# IA (geração de contratos)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Observabilidade (Sentry)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=

# -----------------------------------------------------------------------------
# Rate Limiting distribuído (opcional — recomendado para produção/Vercel)
# -----------------------------------------------------------------------------
# Sem essas variáveis, o rate limit usa memória local (adequado para dev,
# ineficaz em serverless com múltiplas instâncias).
# Crie uma instância gratuita em https://upstash.com e copie as credenciais.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Limites de rate limit de autenticação (valores padrão mostrados)
AUTH_LOGIN_WINDOW_SECONDS="600"
AUTH_LOGIN_MAX_ATTEMPTS="5"
AUTH_LOGIN_BLOCK_SECONDS="900"
AUTH_REGISTER_WINDOW_SECONDS="1800"
AUTH_REGISTER_MAX_ATTEMPTS="5"
AUTH_REGISTER_BLOCK_SECONDS="1800"
AUTH_FORGOT_PASSWORD_WINDOW_SECONDS="1800"
AUTH_FORGOT_PASSWORD_MAX_ATTEMPTS="3"
AUTH_FORGOT_PASSWORD_BLOCK_SECONDS="1800"
AUTH_RESEND_CONFIRMATION_WINDOW_SECONDS="1800"
AUTH_RESEND_CONFIRMATION_MAX_ATTEMPTS="3"
AUTH_RESEND_CONFIRMATION_BLOCK_SECONDS="1800"

# -----------------------------------------------------------------------------
# Cron / Scheduler secrets
# -----------------------------------------------------------------------------
# FINANCE_SCHEDULER_SECRET=
# LEADS_SCHEDULER_SECRET=
# CRON_SECRET=

# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------
# DISABLE_HEAVY_ROUTES=true
