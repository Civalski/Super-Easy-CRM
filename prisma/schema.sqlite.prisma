// Schema Prisma para DESENVOLVIMENTO com SQLite
// Para usar este schema localmente, renomeie para schema.prisma temporariamente

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Cliente {
  id          String      @id @default(cuid())
  nome        String
  email       String?     @unique
  telefone    String?
  empresa     String?
  endereco    String?
  cidade      String?
  estado      String?
  cep         String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  contatos    Contato[]
  oportunidades Oportunidade[]
  tarefas     Tarefa[]
  prospecto   Prospecto?
  
  @@map("clientes")
}

model Contato {
  id          String      @id @default(cuid())
  nome        String
  email       String?
  telefone    String?
  cargo       String?
  clienteId   String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  cliente     Cliente     @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  
  @@map("contatos")
}

model Ambiente {
  id          String      @id @default(cuid())
  nome        String
  descricao   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  oportunidades Oportunidade[]
  
  @@map("ambientes")
}

model Oportunidade {
  id          String      @id @default(cuid())
  titulo      String
  descricao   String?
  valor       Float?
  status      String      @default("prospeccao")
  probabilidade Int       @default(0)
  dataFechamento DateTime?
  clienteId   String
  ambienteId  String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  cliente     Cliente     @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  ambiente    Ambiente    @relation(fields: [ambienteId], references: [id], onDelete: Cascade)
  tarefas     Tarefa[]
  
  @@map("oportunidades")
}

model Tarefa {
  id          String      @id @default(cuid())
  titulo      String
  descricao   String?
  status      String      @default("pendente")
  prioridade  String      @default("media")
  dataVencimento DateTime?
  clienteId   String?
  oportunidadeId String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  cliente     Cliente?    @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  oportunidade Oportunidade? @relation(fields: [oportunidadeId], references: [id], onDelete: Cascade)
  
  @@map("tarefas")
}

model Prospecto {
  id              String    @id @default(cuid())
  cnpj            String    @unique
  cnpjBasico      String
  cnpjOrdem       String
  cnpjDv          String
  razaoSocial     String
  nomeFantasia    String?
  capitalSocial   String?
  porte           String?
  naturezaJuridica String?
  situacaoCadastral String?
  dataAbertura    String?
  matrizFilial    String?
  cnaePrincipal      String?
  cnaePrincipalDesc  String?
  cnaesSecundarios   String?
  tipoLogradouro  String?
  logradouro      String?
  numero          String?
  complemento     String?
  bairro          String?
  cep             String?
  municipio       String
  uf              String
  telefone1       String?
  telefone2       String?
  fax             String?
  email           String?
  status          String    @default("novo")
  observacoes     String?
  prioridade      Int       @default(0)
  lote            String?
  dataImportacao  DateTime  @default(now())
  ultimoContato   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  clienteId       String?   @unique
  cliente         Cliente?  @relation(fields: [clienteId], references: [id])
  
  @@map("prospectos")
}
