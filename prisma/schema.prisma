// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Cliente {
  id          String      @id @default(cuid())
  nome        String
  email       String?     @unique
  telefone    String?
  empresa     String?
  endereco    String?
  cidade      String?
  estado      String?
  cep         String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  contatos    Contato[]
  oportunidades Oportunidade[]
  tarefas     Tarefa[]
  prospecto   Prospecto?
  
  @@map("clientes")
}

model Contato {
  id          String      @id @default(cuid())
  nome        String
  email       String?
  telefone    String?
  cargo       String?
  clienteId   String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  cliente     Cliente     @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  
  @@map("contatos")
}

model Ambiente {
  id          String      @id @default(cuid())
  nome        String
  descricao   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  oportunidades Oportunidade[]
  
  @@map("ambientes")
}

model Oportunidade {
  id          String      @id @default(cuid())
  titulo      String
  descricao   String?
  valor       Float?
  status      String      @default("prospeccao") // prospeccao, qualificacao, proposta, negociacao, fechada, perdida
  probabilidade Int       @default(0) // 0-100
  dataFechamento DateTime?
  clienteId   String
  ambienteId  String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  cliente     Cliente     @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  ambiente    Ambiente    @relation(fields: [ambienteId], references: [id], onDelete: Cascade)
  tarefas     Tarefa[]
  
  @@map("oportunidades")
}

model Tarefa {
  id          String      @id @default(cuid())
  titulo      String
  descricao   String?
  status      String      @default("pendente") // pendente, em_andamento, concluida
  prioridade  String      @default("media") // baixa, media, alta
  dataVencimento DateTime?
  clienteId   String?
  oportunidadeId String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  cliente     Cliente?    @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  oportunidade Oportunidade? @relation(fields: [oportunidadeId], references: [id], onDelete: Cascade)
  
  @@map("tarefas")
}

model Prospecto {
  id              String    @id @default(cuid())
  
  // Dados de identificação (do .parquet)
  cnpj            String    @unique  // CNPJ completo para evitar duplicatas
  cnpjBasico      String               // "20046506"
  cnpjOrdem       String               // "1"
  cnpjDv          String               // "49"
  
  // Dados da empresa
  razaoSocial     String               // "RAZAO SOCIAL / NOME EMPRESARIAL"
  nomeFantasia    String?              // "NOME FANTASIA"
  capitalSocial   String?              // "CAPITAL SOCIAL"
  porte           String?              // "PORTE DA EMPRESA"
  naturezaJuridica String?             // "NATUREZA JURIDICA"
  situacaoCadastral String?            // "SITUAÇÃO CADASTRAL"
  dataAbertura    String?              // "DATA DE INÍCIO DE ATIVIDADE"
  matrizFilial    String?              // "MATRIZ/FILIAL"
  
  // CNAE
  cnaePrincipal      String?           // "COD ATIVIDADE PRINCIPAL"
  cnaePrincipalDesc  String?           // "ATIVIDADE PRINCIPAL"
  cnaesSecundarios   String?           // "COD ATIVIDADES SECUNDARIAS"
  
  // Endereço
  tipoLogradouro  String?
  logradouro      String?
  numero          String?
  complemento     String?
  bairro          String?
  cep             String?
  municipio       String
  uf              String
  
  // Contato
  telefone1       String?
  telefone2       String?
  fax             String?
  email           String?
  
  // Controle de Prospecção
  status          String    @default("novo")  // novo | em_contato | qualificado | descartado | convertido
  observacoes     String?
  prioridade      Int       @default(0)       // 0-5 estrelas
  lote            String?                     // Lote de importação (A, B, C... Z, A1, B1...)
  
  // Datas
  dataImportacao  DateTime  @default(now())
  ultimoContato   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Referência para cliente (após conversão)
  clienteId       String?   @unique
  cliente         Cliente?  @relation(fields: [clienteId], references: [id])
  
  @@map("prospectos")
}
