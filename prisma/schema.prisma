// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // 🏠 Modo DESENVOLVIMENTO - SQLite local
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Cliente {
  id          String      @id @default(cuid())
  nome        String
  email       String?     @unique
  telefone    String?
  empresa     String?
  endereco    String?
  cidade      String?
  estado      String?
  cep         String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  contatos    Contato[]
  oportunidades Oportunidade[]
  tarefas     Tarefa[]
  prospecto   Prospecto?
  
  @@map("clientes")
}

model Contato {
  id          String      @id @default(cuid())
  nome        String
  email       String?
  telefone    String?
  cargo       String?
  clienteId   String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  cliente     Cliente     @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  
  @@map("contatos")
}

model Ambiente {
  id          String      @id @default(cuid())
  nome        String
  descricao   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  oportunidades Oportunidade[]
  
  @@map("ambientes")
}

model Oportunidade {
  id          String      @id @default(cuid())
  titulo      String
  descricao   String?
  valor       Float?
  status      String      @default("prospeccao") // prospeccao, qualificacao, proposta, negociacao, fechada, perdida
  probabilidade Int       @default(0) // 0-100
  dataFechamento DateTime?
  clienteId   String
  ambienteId  String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  cliente     Cliente     @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  ambiente    Ambiente    @relation(fields: [ambienteId], references: [id], onDelete: Cascade)
  tarefas     Tarefa[]
  
  @@map("oportunidades")
}

model Tarefa {
  id          String      @id @default(cuid())
  titulo      String
  descricao   String?
  status      String      @default("pendente") // pendente, em_andamento, concluida
  prioridade  String      @default("media") // baixa, media, alta
  dataVencimento DateTime?
  clienteId   String?
  oportunidadeId String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  cliente     Cliente?    @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  oportunidade Oportunidade? @relation(fields: [oportunidadeId], references: [id], onDelete: Cascade)
  
  @@map("tarefas")
}

model Prospecto {
  id              String    @id @default(cuid())
  
  // Dados de identificação
  cnpj            String    @unique
  cnpjBasico      String
  cnpjOrdem       String
  cnpjDv          String
  
  // Dados da empresa
  razaoSocial     String
  nomeFantasia    String?
  capitalSocial   String?
  porte           String?
  naturezaJuridica String?
  situacaoCadastral String?
  dataAbertura    String?
  matrizFilial    String?
  
  // CNAE
  cnaePrincipal      String?
  cnaePrincipalDesc  String?
  cnaesSecundarios   String?
  
  // Endereço
  tipoLogradouro  String?
  logradouro      String?
  numero          String?
  complemento     String?
  bairro          String?
  cep             String?
  municipio       String
  uf              String
  
  // Contato
  telefone1       String?
  telefone2       String?
  fax             String?
  email           String?
  
  // Controle de Prospecção
  status          String    @default("novo")  // novo | em_contato | qualificado | descartado | convertido
  observacoes     String?
  prioridade      Int       @default(0)       // 0-5 estrelas
  lote            String?                     // Lote de importação
  
  // Datas
  dataImportacao  DateTime  @default(now())
  ultimoContato   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Referência para cliente (após conversão)
  clienteId       String?   @unique
  cliente         Cliente?  @relation(fields: [clienteId], references: [id])
  
  @@map("prospectos")
}
