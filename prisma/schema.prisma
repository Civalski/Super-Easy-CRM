// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // PostgreSQL - Supabase
  // Prisma v7: URLs em prisma.config.ts
  provider = "postgresql"
}

enum GoalMetricType {
  CLIENTES_CONTATADOS
  PROPOSTAS
  CLIENTES_CADASTRADOS
  VENDAS
  QUALIFICACAO
  NEGOCIACAO
  PROSPECCAO
  FATURAMENTO
}

enum GoalPeriodType {
  DAILY
  WEEKLY
  MONTHLY
  CUSTOM
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String?  @unique
  username     String   @unique
  passwordHash String
  role         String   @default("user")
  activeSessionId String?
  subscriptionProvider     String?
  subscriptionExternalId   String?  @unique
  subscriptionStatus       String   @default("inactive")
  subscriptionPlanCode     String?
  subscriptionCheckoutUrl  String?
  subscriptionNextBillingAt DateTime?
  subscriptionLastWebhookAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  usedRegistrationCodes RegistrationCode[]
  goals                 Goal[]
  motivosPerda          MotivoPerda[]
  clientes              Cliente[]
  contatos              Contato[]
  oportunidades         Oportunidade[]
  pedidos               Pedido[]
  tarefas               Tarefa[]
  prospectos            Prospecto[]
  prospectoAgendamentos ProspectoEnvioAgendado[]
  metaContato           MetaContatoConfig?
  workspacesOwned       Workspace[]              @relation("WorkspaceOwner")
  workspaceMemberships  WorkspaceMember[]
  notas                Nota[]
  followUpAttempts      FollowUpAttempt[]
  produtosServicos      ProdutoServico[]
  pedidoItens           PedidoItem[]
  contasReceber         ContaReceber[]
  movimentosFinanceiros MovimentoFinanceiro[]
  pdfConfig             PdfConfig?
  fornecedores          Fornecedor[]
  funcionarios          Funcionario[]

  @@map("users")
}

model RegistrationCode {
  id        String    @id @default(cuid())
  codeHash  String    @unique
  usedAt    DateTime?
  usedById  String?
  createdAt DateTime  @default(now())

  usedBy User? @relation(fields: [usedById], references: [id], onDelete: SetNull)

  @@map("registration_codes")
}

model Goal {
  id         String         @id @default(cuid())
  userId     String
  title      String?
  metricType GoalMetricType
  periodType GoalPeriodType
  target     Int
  startDate  DateTime?
  endDate    DateTime?
  weekDays   Int[]          @default([])
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshots GoalSnapshot[]

  @@map("goals")
}

model GoalSnapshot {
  id          String   @id @default(cuid())
  goalId      String
  periodStart DateTime
  periodEnd   DateTime
  current     Int
  target      Int
  progress    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([goalId, periodStart, periodEnd])
  @@map("goal_snapshots")
}

model Cliente {
  id                   String   @id @default(cuid())
  numero               Int      @unique @default(autoincrement())
  userId               String
  nome                 String
  email                String?
  telefone             String?
  empresa              String?
  endereco             String?
  cidade               String?
  estado               String?
  cep                  String?
  cargo                String?
  documento            String?
  website              String?
  dataNascimento       String?
  observacoes          String?
  camposPersonalizados Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  contatos       Contato[]
  oportunidades  Oportunidade[]
  tarefas        Tarefa[]
  prospecto      Prospecto?
  contasReceber  ContaReceber[]
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([id, userId])
  @@unique([userId, email])
  @@index([userId])
  @@index([userId, createdAt])
  @@map("clientes")
}

model Fornecedor {
  id          String   @id @default(cuid())
  userId      String
  nome        String
  email       String?
  telefone    String?
  documento   String?
  empresa     String?
  endereco    String?
  cidade      String?
  estado      String?
  cep         String?
  observacoes String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  contasReceber ContaReceber[]

  @@index([userId])
  @@index([userId, nome])
  @@map("fornecedores")
}

model Funcionario {
  id          String   @id @default(cuid())
  userId      String
  nome        String
  email       String?
  telefone    String?
  documento   String?
  cargo       String?
  departamento String?
  observacoes String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  contasReceber ContaReceber[]

  @@index([userId])
  @@index([userId, nome])
  @@map("funcionarios")
}

model Contato {
  id        String   @id @default(cuid())
  userId    String
  nome      String
  email     String?
  telefone  String?
  cargo     String?
  clienteId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cliente Cliente @relation(fields: [clienteId, userId], references: [id, userId], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, clienteId])
  @@map("contatos")
}

model Oportunidade {
  id                     String    @id @default(cuid())
  numero                 Int       @unique @default(autoincrement())
  userId                 String
  titulo                 String
  descricao              String?
  valor                  Float?
  status                 String    @default("orcamento") // sem_contato, em_potencial, orcamento, fechada, perdida
  statusAnterior         String?
  motivoPerda            String?
  probabilidade          Int       @default(0) // 0-100
  dataFechamento         DateTime?
  formaPagamento         String?
  parcelas               Int?
  desconto               Float?
  proximaAcaoEm          DateTime?
  canalProximaAcao       String?
  responsavelProximaAcao String?
  lembreteProximaAcao    Boolean   @default(false)
  clienteId              String
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  cliente          Cliente           @relation(fields: [clienteId, userId], references: [id, userId], onDelete: Cascade)
  tarefas          Tarefa[]
  pedido           Pedido?
  contasReceber    ContaReceber[]
  followUpAttempts FollowUpAttempt[]
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([id, userId])
  @@index([userId])
  @@index([userId, clienteId])
  @@index([userId, status, createdAt])
  @@map("oportunidades")
}

model Pedido {
  id                  String    @id @default(cuid())
  numero              Int       @unique @default(autoincrement())
  userId              String
  oportunidadeId      String    @unique
  statusEntrega       String    @default("pendente") // pendente, em_preparacao, enviado, entregue
  pagamentoConfirmado Boolean   @default(false)
  formaPagamento      String?
  dataEntrega         DateTime?
  dataAprovacao       DateTime  @default(now())
  observacoes         String?
  totalBruto          Float     @default(0)
  totalDesconto       Float     @default(0)
  totalLiquido        Float     @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  oportunidade  Oportunidade   @relation(fields: [oportunidadeId, userId], references: [id, userId], onDelete: Cascade)
  itens         PedidoItem[]
  contasReceber ContaReceber?

  @@unique([id, userId])
  @@unique([oportunidadeId, userId])
  @@index([userId, statusEntrega])
  @@index([userId, dataEntrega])
  @@index([userId, createdAt])
  @@map("pedidos")
}

model MotivoPerda {
  id        String   @id @default(cuid())
  nome      String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, nome])
  @@index([userId])
  @@map("motivos_perda")
}

model Tarefa {
  id             String    @id @default(cuid())
  userId         String
  titulo         String
  descricao      String?
  status         String    @default("pendente") // pendente, em_andamento, concluida
  prioridade     String    @default("media") // baixa, media, alta
  dataVencimento DateTime?
  clienteId      String?
  oportunidadeId String?

  notificar           Boolean @default(false)
  notificacaoExcluida Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cliente      Cliente?      @relation(fields: [clienteId, userId], references: [id, userId], onDelete: Cascade)
  oportunidade Oportunidade? @relation(fields: [oportunidadeId, userId], references: [id, userId], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, clienteId])
  @@index([userId, oportunidadeId])
  @@index([userId, status, prioridade, createdAt])
  @@map("tarefas")
}

model Prospecto {
  id     String @id @default(cuid())
  userId String

  // Dados de identificação
  cnpj       String
  cnpjBasico String
  cnpjOrdem  String
  cnpjDv     String

  // Dados da empresa
  razaoSocial       String
  nomeFantasia      String?
  capitalSocial     String?
  porte             String?
  naturezaJuridica  String?
  situacaoCadastral String?
  dataAbertura      String?
  matrizFilial      String?

  // CNAE
  cnaePrincipal     String?
  cnaePrincipalDesc String?
  cnaesSecundarios  String?

  // Endereço
  tipoLogradouro String?
  logradouro     String?
  numero         String?
  complemento    String?
  bairro         String?
  cep            String?
  municipio      String
  uf             String

  // Contato
  telefone1 String?
  telefone2 String?
  fax       String?
  email     String?

  // Controle de Prospecção
  status      String  @default("novo") // novo | em_contato | qualificado | aguardando_orcamento | descartado | convertido
  observacoes String?
  prioridade  Int     @default(0) // 0-5 estrelas
  lote        String? // Lote de importação

  // Datas
  dataImportacao DateTime  @default(now())
  ultimoContato  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Referência para cliente (após conversão)
  clienteId String?  @unique
  cliente   Cliente? @relation(fields: [clienteId, userId], references: [id, userId])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, cnpj])
  @@unique([clienteId, userId])
  @@index([userId])
  @@index([userId, status, createdAt])
  @@map("prospectos")
}

model ProspectoEnvioAgendado {
  id          String    @id @default(cuid())
  userId      String
  lote        String?
  dataEnvio   String // YYYY-MM-DD in Brazil timezone
  status      String    @default("pendente") // pendente | processando | processado | cancelado | erro
  enviados    Int       @default(0)
  executadoEm DateTime?
  erro        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dataEnvio, status])
  @@index([userId, lote, status])
  @@map("prospecto_envio_agendado")
}

model PdfConfig {
  id           String   @id @default(cuid())
  userId       String   @unique
  nomeEmpresa  String?
  nomeVendedor String?
  telefone     String?
  email        String?
  site         String?
  rodape       String?
  corPrimaria  String?
  validadeDias Int?
  logoBase64   String?
  logoPosicao  String?  @default("topo")
  tributacaoInclusa Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("pdf_config")
}

model MetaContatoConfig {
  id         String   @id @default(cuid())
  userId     String   @unique
  metaDiaria Int      @default(25)
  ativo      Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user           User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  diasEsquecidos MetaContatoDiaEsquecido[]

  @@map("meta_contato_config")
}

model MetaContatoDiaEsquecido {
  id        String   @id @default(cuid())
  configId  String
  data      String // YYYY-MM-DD format
  createdAt DateTime @default(now())

  config MetaContatoConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@unique([configId, data])
  @@map("meta_contato_dias_esquecidos")
}

model Nota {
  id        String   @id @default(cuid())
  userId    String
  tipo      String   @default("bloco") // bloco | email | whatsapp
  titulo    String?
  descricao String?
  conteudo  String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempts FollowUpAttempt[]

  @@unique([id, userId])
  @@index([userId, tipo])
  @@map("notas")
}

model FollowUpAttempt {
  id             String   @id @default(cuid())
  userId         String
  oportunidadeId String
  notaId         String?
  canal          String
  mensagem       String
  resultado      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  oportunidade Oportunidade @relation(fields: [oportunidadeId, userId], references: [id, userId], onDelete: Cascade)
  nota         Nota?        @relation(fields: [notaId], references: [id], onDelete: SetNull)

  @@index([userId, oportunidadeId, createdAt])
  @@map("followup_attempts")
}

model ProdutoServico {
  id                  String   @id @default(cuid())
  userId              String
  codigo              String?
  nome                String
  categoria           String?
  marca               String?
  codigoBarras        String?
  tipo                String   @default("servico") // produto | servico
  unidade             String   @default("UN") // UN | CX | KG | M | M2 | M3 | L | HORA | DIARIA | MES
  descricao           String?
  observacoesInternas String?
  precoPadrao         Float    @default(0)
  custoPadrao         Float    @default(0)
  comissaoPercentual  Float    @default(0)
  controlaEstoque     Boolean  @default(false)
  estoqueAtual        Float    @default(0)
  estoqueMinimo       Float    @default(0)
  tempoPadraoMinutos  Int?
  garantiaDias        Int?
  prazoEntregaDias    Int?
  ativo               Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  pedidoItens PedidoItem[]

  @@unique([id, userId])
  @@unique([userId, codigo])
  @@index([userId, ativo])
  @@index([userId, tipo, ativo])
  @@index([userId, categoria])
  @@index([userId, marca])
  @@map("produtos_servicos")
}

model PedidoItem {
  id               String   @id @default(cuid())
  userId           String
  pedidoId         String
  produtoServicoId String?
  descricao        String
  quantidade       Float    @default(1)
  precoUnitario    Float    @default(0)
  desconto         Float    @default(0)
  subtotal         Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  pedido         Pedido          @relation(fields: [pedidoId, userId], references: [id, userId], onDelete: Cascade)
  produtoServico ProdutoServico? @relation(fields: [produtoServicoId], references: [id], onDelete: SetNull)

  @@index([userId, pedidoId])
  @@index([pedidoId])
  @@map("pedido_itens")
}

model ContaReceber {
  id                       String    @id @default(cuid())
  userId                   String
  pedidoId                 String?   @unique
  oportunidadeId           String?
  clienteId                String?
  fornecedorId             String?
  funcionarioId            String?
  ambiente                 String    @default("geral") // geral | pessoal
  tipo                     String    @default("receber") // receber | pagar
  descricao                String?
  valorTotal               Float
  valorRecebido            Float     @default(0)
  autoDebito               Boolean   @default(false)
  grupoParcelaId           String?
  numeroParcela            Int?
  totalParcelas            Int?
  recorrenteMensal         Boolean   @default(false)
  recorrenciaAtiva         Boolean   @default(false)
  recorrenciaDiaVencimento Int?
  dataVencimento           DateTime?
  status                   String    @default("pendente") // pendente | parcial | pago | atrasado | cancelado
  multaPorAtrasoPercentual  Float?
  multaPorAtrasoValor      Float?
  multaPorAtrasoPeriodo    String?   // dia | semana | mes
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  pedido       Pedido?               @relation(fields: [pedidoId], references: [id], onDelete: SetNull)
  oportunidade Oportunidade?         @relation(fields: [oportunidadeId], references: [id], onDelete: SetNull)
  cliente      Cliente?             @relation(fields: [clienteId, userId], references: [id, userId], onDelete: SetNull)
  fornecedor   Fornecedor?          @relation(fields: [fornecedorId], references: [id], onDelete: SetNull)
  funcionario  Funcionario?         @relation(fields: [funcionarioId], references: [id], onDelete: SetNull)
  movimentos   MovimentoFinanceiro[]

  @@unique([id, userId])
  @@index([userId, oportunidadeId])
  @@index([userId, ambiente, tipo, status, dataVencimento])
  @@index([userId, recorrenteMensal, recorrenciaAtiva])
  @@index([userId, createdAt])
  @@index([userId, grupoParcelaId])
  @@map("contas_receber")
}

model MovimentoFinanceiro {
  id             String   @id @default(cuid())
  userId         String
  contaReceberId String
  tipo           String   @default("entrada") // entrada | estorno
  valor          Float
  dataMovimento  DateTime @default(now())
  observacoes    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  contaReceber ContaReceber @relation(fields: [contaReceberId, userId], references: [id, userId], onDelete: Cascade)

  @@index([userId, dataMovimento])
  @@index([contaReceberId])
  @@index([contaReceberId, createdAt])
  @@map("movimentos_financeiros")
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner   User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members WorkspaceMember[]

  @@index([ownerId])
  @@map("workspaces")
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        String   @default("vendedor") // owner | gestor | vendedor
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map("workspace_members")
}
