{
  "name": "arker-crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:frontend",
    "dev:first": "npm run setup:dev && npm run dev:frontend",
    "dev:frontend": "powershell -ExecutionPolicy Bypass -File ./scripts/kill-ports.ps1 && next dev",
    "build": "npm run setup:prod && next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test:smoke": "node scripts/smoke-api-guards.js",
    "check": "npm run lint && npm run type-check && npm run test:smoke",
    "setup:dev": "node scripts/setup-dev.js && npm run db:generate",
    "setup:prod": "node scripts/setup-prod.js && npm run db:generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:push:dev": "prisma db push && npm run db:generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:status": "prisma migrate status",
    "db:studio": "prisma studio",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:export-usuarios": "npx tsx scripts/export-usuarios-csv.ts",
    "db:seed-codes": "node scripts/seed-registration-codes.js",
    "db:reset-users": "npx tsx scripts/reset-users.ts",
    "db:backup": "node scripts/backup-db.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@heroicons/react": "^2.2.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@react-email/components": "^1.0.9",
    "@react-email/render": "^2.0.4",
    "@stripe/react-stripe-js": "^5.6.1",
    "@stripe/stripe-js": "^8.9.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.1",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.9.3",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "swr": "^2.4.1",
    "zod": "^4.3.6"
  },
  "overrides": {
    "hono": "^4.12.4",
    "@hono/node-server": "^1.19.10",
    "lodash": "^4.17.22"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.3.3",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "husky": "^9.1.7",
    "pg": "^8.20.0",
    "postcss": "^8",
    "prisma": "^7.4.2",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
