{
  "name": "arker-crm",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File ./scripts/kill-ports.ps1 && concurrently \"npm run dev:frontend\" \"npm run dev:backend\" \"npm run dev:electron\" --names \"NEXT,PYTHON,ELECTRON\" --prefix-colors \"cyan,magenta,blue\"",
    "dev:frontend": "next dev",
    "dev:backend": "cd backend && powershell -ExecutionPolicy Bypass -File ./start-backend.ps1",
    "dev:electron": "wait-on http://localhost:3000 && electron .",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "npx tsx prisma/seed.ts",
    "pack": "electron-builder --dir",
    "dist": "npm run build && node scripts/prepare-standalone.js && electron-builder",
    "build:dist": "powershell -ExecutionPolicy Bypass -File ./scripts/build-all.ps1"
  },
  "build": {
    "appId": "com.arkercrm.app",
    "productName": "Arker CRM",
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "files": [
      "public/**/*",
      "electron/**/*",
      "package.json",
      "next.config.js"
    ],
    "asar": true,
    "extraResources": [
      "prisma/**/*",
      "scripts/**/*",
      {
        "from": "dist-python/backend-api.exe",
        "to": "backend-api.exe"
      },
      {
        "from": "node.exe",
        "to": "node.exe"
      },
      {
        "from": ".next/standalone",
        "to": "standalone"
      },
      {
        "from": ".next/standalone/node_modules",
        "to": "standalone/node_modules"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Arker CRM",
      "uninstallDisplayName": "Arker CRM",
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "installerHeaderIcon": "public/icon.ico"
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^5.9.1",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^0.344.0",
    "next": "14.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.3",
    "sweetalert2": "^11.26.17",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "concurrently": "^9.1.2",
    "cross-env": "^10.1.0",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "eslint": "^8",
    "eslint-config-next": "14.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "postcss": "^8",
    "prisma": "^5.9.1",
    "tailwindcss": "^3.3.0",
    "typescript": "^5",
    "wait-on": "^9.0.3"
  }
}