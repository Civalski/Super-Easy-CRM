{
  "name": "arker-crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run setup:dev && npm run dev:frontend",
    "dev:frontend": "powershell -ExecutionPolicy Bypass -File ./scripts/kill-ports.ps1 && next dev",
    "build": "npm run setup:prod && next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test:smoke": "node scripts/smoke-api-guards.js",
    "check": "npm run lint && npm run type-check && npm run test:smoke",
    "setup:dev": "node scripts/setup-dev.js && npm run db:generate",
    "setup:prod": "node scripts/setup-prod.js && npm run db:generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:push:dev": "prisma db push && npm run db:generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:status": "prisma migrate status",
    "db:studio": "prisma studio",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:seed-codes": "node scripts/seed-registration-codes.js"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@pdf-lib/fontkit": "^1.1.1",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "pdf-lib": "^1.17.1",
    "pg": "^8.19.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sweetalert2": "^11.26.21",
    "swr": "^2.4.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "baseline-browser-mapping": "^2.10.0",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8",
    "prisma": "^7.4.2",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
