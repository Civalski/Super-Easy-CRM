{
  "name": "arker-crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run setup:dev && npm run dev:frontend",
    "dev:frontend": "powershell -ExecutionPolicy Bypass -File ./scripts/kill-ports.ps1 && next dev",
    "build": "npm run setup:prod && npm run db:generate && next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test:smoke": "node scripts/smoke-api-guards.js",
    "check": "npm run lint && npm run type-check && npm run test:smoke",
    "setup:dev": "node scripts/setup-dev.js && npm run db:generate",
    "setup:prod": "node scripts/setup-prod.js && npm run db:generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:push:dev": "prisma db push --skip-generate && npm run db:generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:status": "prisma migrate status",
    "db:studio": "prisma studio",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:seed-codes": "node scripts/seed-registration-codes.js"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.344.0",
    "next": "14.2.35",
    "next-auth": "^4.24.13",
    "pg": "^8.19.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sweetalert2": "^11.26.21",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.35",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.27",
    "baseline-browser-mapping": "^2.10.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "prisma": "^7.4.2",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
